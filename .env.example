# ========================================
# Docker Mode Selection
# ========================================
# MODE controls which Dockerfiles and commands are used
# For development (default): Use Dockerfile.dev with hot-reload
# For production: Use Dockerfile with optimized builds

# Development Mode (default) - Hot-reload enabled
BACKEND_DOCKERFILE=Dockerfile.dev
FRONTEND_DOCKERFILE=Dockerfile.dev
BACKEND_COMMAND=air -c .air.toml
FRONTEND_COMMAND=npm run dev -- --host 0.0.0.0
FRONTEND_INTERNAL_PORT=5173

# Production Mode - Uncomment these for production:
# BACKEND_DOCKERFILE=Dockerfile
# FRONTEND_DOCKERFILE=Dockerfile
# BACKEND_COMMAND=./api
# FRONTEND_COMMAND=nginx -g daemon off;
# FRONTEND_INTERNAL_PORT=80

# ========================================
# PostgreSQL Configuration
# ========================================
POSTGRES_DB=dentist_db
POSTGRES_USER=dentist_user
# Default password for development (CHANGE IN PRODUCTION!)
POSTGRES_PASSWORD=dentist_dev_pass
POSTGRES_PORT=5433  # Using 5433 to avoid conflicts with local PostgreSQL

# Database Connection URL
# Format: postgres://user:password@host:port/database?sslmode=disable
# For Docker: use service name 'postgres' as host (internal port is still 5432)
# Default for development (CHANGE PASSWORD IN PRODUCTION!)
DATABASE_URL=postgres://dentist_user:dentist_dev_pass@postgres:5432/dentist_db?sslmode=disable

# Backend Configuration
BACKEND_PORT=8080
FRONTEND_URL=http://localhost:5173

# JWT Authentication
# IMPORTANT: Generate a secure random string (minimum 32 characters)
# Example: openssl rand -base64 32
# Default for development (CHANGE IN PRODUCTION!)
JWT_SECRET=insecure_dev_secret_min_32_chars
JWT_EXPIRATION=24h

# File Upload Configuration
UPLOAD_PATH=./uploads
UPLOAD_URL_PREFIX=/uploads

# Telegram Notifications (contact form submissions are sent via Telegram)
# Create a bot via @BotFather, then get the chat ID by messaging the bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Frontend Configuration
# In development: http://localhost:8080/api
# In production: https://yourdomain.com/api or http://yourserver.com/api
VITE_API_URL=http://localhost:8080/api

# Production Settings (uncomment for production)
# ENVIRONMENT=production
# FRONTEND_URL=https://yourdomain.com
# VITE_API_URL=https://yourdomain.com/api
# DATABASE_URL=postgres://dentist_user:your_password@postgres:5432/dentist_db?sslmode=require
