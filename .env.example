# Environment
ENVIRONMENT=development

# PostgreSQL Configuration
POSTGRES_DB=dentist_db
POSTGRES_USER=dentist_user
POSTGRES_PASSWORD=your_secure_password_here_change_me
POSTGRES_PORT=5432

# Database Connection URL
# Format: postgres://user:password@host:port/database?sslmode=disable
# For Docker: use service name 'postgres' as host
DATABASE_URL=postgres://dentist_user:your_secure_password_here_change_me@postgres:5432/dentist_db?sslmode=disable

# Backend Configuration
BACKEND_PORT=8080
FRONTEND_URL=http://localhost:5173

# JWT Authentication
# IMPORTANT: Generate a secure random string (minimum 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_change_me_now
JWT_EXPIRATION=24h

# SMTP Email Configuration
# Gmail example - use App Password, not regular password
# Get App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
EMAIL_RECIPIENT=dentist@example.com

# Frontend Configuration
# In development: http://localhost:8080/api
# In production: https://yourdomain.com/api or http://yourserver.com/api
VITE_API_URL=http://localhost:8080/api

# Production Settings (uncomment for production)
# ENVIRONMENT=production
# FRONTEND_URL=https://yourdomain.com
# VITE_API_URL=https://yourdomain.com/api
# DATABASE_URL=postgres://dentist_user:your_password@postgres:5432/dentist_db?sslmode=require
