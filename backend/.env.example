# Server Configuration
PORT=8080
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgres://dentist_user:dentist_dev_pass@localhost:5432/dentist_db?sslmode=disable

# JWT Authentication
# Generate: openssl rand -base64 32
JWT_SECRET=insecure_dev_secret_min_32_chars
JWT_EXPIRATION=24h

# File Upload
UPLOAD_PATH=./uploads
UPLOAD_URL_PREFIX=/uploads

# Telegram Notifications (contact form submissions are sent via Telegram)
# Create a bot via @BotFather, then get the chat ID by messaging the bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
