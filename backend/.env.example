# Server Configuration
PORT=8080
FRONTEND_URL=http://localhost:5173

# SMTP Configuration (Email Settings)
# For Gmail: Use smtp.gmail.com with port 587
# You'll need to create an App Password: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Recipient Email (Where contact form submissions will be sent)
EMAIL_RECIPIENT=dentist@example.com
